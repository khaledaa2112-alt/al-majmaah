@page
@model مشروع_1.Pages.InstructorProfileModel
@{
    Layout = null;
    // بيانات المحاضر
    var doctorName = "د. محمد الطوخي";
    var employeeId = "12345";
    var email = "m.tokhi@mu.edu.sa";
    var specialty = "علوم الحاسب - هندسة البرمجيات";
    var college = "كلية علوم الحاسب والمعلومات";
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>معلومات المحاضر - جامعة المجمعة</title>
    <style>
        body {
            margin: 0;
            background-image: url('/images/IM.jpg');
            background-size: cover;
            background-attachment: fixed;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            direction: rtl;
        }

        .main-overlay {
            background-color: rgba(0, 0, 0, 0.75);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .profile-card {
            background: rgba(255, 255, 255, 0.95);
            padding: 40px;
            border-radius: 25px;
            width: 100%;
            max-width: 450px;
            text-align: center;
            box-shadow: 0 15px 35px rgba(0,0,0,0.5);
        }

        .profile-img {
            width: 130px;
            height: 130px;
            border-radius: 50%;
            border: 5px solid #28a745;
            margin-bottom: 20px;
            object-fit: cover;
        }

        .profile-card h2 {
            color: #28a745;
            margin-bottom: 25px;
            border-bottom: 2px solid #eee;
            padding-bottom: 10px;
        }

        .info-group {
            text-align: right;
            margin-bottom: 15px;
            padding: 10px;
            background: #f8f9fa;
            border-radius: 10px;
            border-right: 5px solid #28a745;
        }

        .info-label {
            font-weight: bold;
            color: #28a745;
            display: block;
            font-size: 0.9rem;
        }

        .info-value {
            color: #333;
            font-size: 1.1rem;
            word-wrap: break-word;
        }

        .back-btn {
            display: inline-block;
            margin-top: 25px;
            padding: 10px 30px;
            background-color: #666;
            color: white;
            text-decoration: none;
            border-radius: 10px;
            transition: 0.3s;
        }

            .back-btn:hover {
                background-color: #444;
            }
    </style>
</head>
<body>

    <div class="main-overlay">
        <div class="profile-card">
            <img src="/images/ss.png" class="profile-img" alt="صورة المحاضر" />

            <h2>بيانات المحاضر</h2>

            <div class="info-group">
                <span class="info-label">الاسم الكامل</span>
                <span class="info-value">@doctorName</span>
            </div>

            <div class="info-group">
                <span class="info-label">الرقم الوظيفي</span>
                <span class="info-value">@employeeId</span>
            </div>

            <div class="info-group">
                <span class="info-label">البريد الإلكتروني الجامعي</span>
                <span class="info-value">@email</span>
            </div>

            <div class="info-group">
                <span class="info-label">التخصص الأساسي</span>
                <span class="info-value">@specialty</span>
            </div>

            <div class="info-group">
                <span class="info-label">الكلية</span>
                <span class="info-value">@college</span>
            </div>

            <a href="/FacultyDashboard" class="back-btn">العودة للوحة التحكم</a>
        </div>
    </div>

</body>
</html>