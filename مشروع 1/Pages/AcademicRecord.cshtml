@page
@model مشروع_1.Pages.AcademicRecordModel
@{
    Layout = null;
    // جلب الرقم الجامعي من الجلسة (Session)
    var studentId = HttpContext.Session.GetString("UserStudentId");
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>السجل الأكاديمي - جامعة المجمعة</title>
    <style>
        body {
            margin: 0;
            background-image: url('/images/IM.jpg');
            background-size: cover;
            background-repeat: no-repeat;
            background-attachment: fixed;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            direction: rtl;
        }

        .main-overlay {
            background-color: rgba(0, 0, 0, 0.7);
            min-height: 100vh;
            padding: 40px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .record-card {
            background-color: rgba(255, 255, 255, 0.95);
            padding: 30px;
            border-radius: 20px;
            width: 95%;
            max-width: 700px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

            .record-card h2 {
                color: #28a745;
                text-align: center;
                border-bottom: 2px solid #28a745;
                padding-bottom: 10px;
                margin-bottom: 25px;
            }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        th {
            background-color: #28a745;
            color: white;
            padding: 12px;
            text-align: right;
        }

        td {
            padding: 12px;
            border-bottom: 1px solid #ddd;
            color: #333;
        }

        tr:hover {
            background-color: #f1f1f1;
        }

        .star-mark {
            color: #d2b48c;
            font-weight: bold;
            font-size: 1.2rem;
        }

        .back-btn {
            display: inline-block;
            margin-top: 10px;
            background-color: #28a745;
            color: white;
            padding: 10px 25px;
            border-radius: 8px;
            text-decoration: none;
            transition: 0.3s;
        }

            .back-btn:hover {
                background-color: #218838;
            }
    </style>
</head>
<body>

    <div class="main-overlay">
        <div class="record-card">
            <img src="/images/logo.png" width="80" style="display:block; margin: 0 auto 10px;" />
            <h2>السجل الأكاديمي للطالب</h2>

            <table>
                <thead>
                    <tr>
                        <th>اسم المقرر</th>
                        <th>عدد الساعات</th>
                        <th>التقدير</th>
                    </tr>
                </thead>
                <tbody>
                    @if (studentId == "461102138")
                    {
                        <tr>
                            <td>برمجة مرئية</td>
                            <td>3</td>
                            <td class="star-mark">*</td>
                        </tr>
                        <tr>
                            <td>هياكل بيانات</td>
                            <td>3</td>
                            <td class="star-mark">*</td>
                        </tr>
                        <tr>
                            <td>نظم إدارة قواعد بيانات</td>
                            <td>3</td>
                            <td class="star-mark">*</td>
                        </tr>
                    }
                    else if (studentId == "441001234")
                    {
                        <tr>
                            <td>الديناميكا الحرارية</td>
                            <td>3</td>
                            <td class="star-mark">*</td>
                        </tr>
                        <tr>
                            <td>الفيزياء الحديثة</td>
                            <td>3</td>
                            <td class="star-mark">*</td>
                        </tr>
                        <tr>
                            <td>فيزياء البيئة</td>
                            <td>3</td>
                            <td class="star-mark">*</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div style="text-align: center;">
                <a href="/StudentDashboard" class="back-btn">العودة للوحة التحكم</a>
            </div>
        </div>
    </div>

</body>
</html>