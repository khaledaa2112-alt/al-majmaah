@page
@model مشروع_1.Pages.SanctionsModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>العقوبات - جامعة المجمعة</title>
    <style>
        body {
            margin: 0;
            background-image: url('/images/IM.jpg');
            background-size: cover;
            background-repeat: no-repeat;
            background-attachment: fixed;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            direction: rtl;
        }

        .main-overlay {
            background-color: rgba(0, 0, 0, 0.7);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .card {
            background-color: rgba(255, 255, 255, 0.95);
            padding: 40px;
            border-radius: 20px;
            width: 100%;
            max-width: 450px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            border-top: 8px solid #28a745;
        }

        .icon {
            font-size: 60px;
            color: #28a745;
            margin-bottom: 20px;
        }

        .message-box {
            background-color: #f1f8e9;
            color: #1b5e20;
            padding: 25px;
            border-radius: 12px;
            font-size: 1.4rem;
            font-weight: bold;
            margin-bottom: 25px;
            border: 1px solid #c8e6c9;
        }

        .back-btn {
            display: inline-block;
            background-color: #28a745;
            color: white;
            padding: 12px 35px;
            border-radius: 8px;
            text-decoration: none;
            transition: 0.3s;
            font-weight: bold;
        }

            .back-btn:hover {
                background-color: #218838;
                transform: translateY(-3px);
            }
    </style>
</head>
<body>

    <div class="main-overlay">
        <div class="card">
            <div class="icon">🛡️</div>
            <h2>سجل الانضباط والعقوبات</h2>

            <div class="message-box">
                لا يوجد عقوبات مسجلة
            </div>

            <p style="color: #555; margin-bottom: 30px; line-height: 1.6;">
                سجلك الأكاديمي نظيف تماماً. <br>
                نقدر التزامك بأنظمة ولوائح الجامعة.
            </p>

            <a href="/StudentDashboard" class="back-btn">العودة للوحة التحكم</a>
        </div>
    </div>

</body>
</html>