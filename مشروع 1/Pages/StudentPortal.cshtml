@page
@model مشروع_1.Pages.StudentPortalModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>تسجيل الدخول - جامعة المجمعة</title>
    <style>
        body {
            margin: 0;
            background-image: url('/images/IM.jpg');
            background-size: cover;
            background-position: center;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            /* نوع الخط مطابق للصورة المرفقة */
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .login-box {
            /* مربع أبيض بالكامل بدون شفافية */
            background: #ffffff;
            padding: 45px 40px;
            border-radius: 30px;
            width: 420px;
            text-align: center;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
        }

        .logo-img {
            width: 160px;
            height: auto;
            margin-bottom: 30px;
        }

        h2 {
            color: #28a745;
            margin-top: 0;
            margin-bottom: 25px;
            font-size: 1.8rem;
            font-weight: 500;
        }

        .input-label {
            display: block;
            text-align: right;
            font-weight: bold;
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

        input {
            width: 100%;
            padding: 15px;
            margin-bottom: 20px;
            border: 1px solid #e0e0e0;
            border-radius: 12px;
            box-sizing: border-box;
            background-color: #ffffff;
            font-size: 0.9rem;
        }

        button {
            width: 100%;
            padding: 15px;
            background: #28a745;
            color: white;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            font-size: 1.1rem;
            font-weight: bold;
            margin-top: 10px;
            transition: background 0.3s;
        }

            button:hover {
                background: #218838;
            }

        .back-home-link {
            display: inline-block;
            margin-top: 25px;
            color: #666;
            text-decoration: none;
            font-size: 1.1rem;
            transition: color 0.3s;
        }

            /* لا يوجد خط تحت الرابط عند مرور الماوس */
            .back-home-link:hover {
                color: #333;
                text-decoration: none;
            }

        .error {
            color: #dc3545;
            padding: 10px;
            margin-bottom: 15px;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <div class="login-box">
        <img src="/images/logo.png" alt="جامعة المجمعة" class="logo-img" onerror="this.style.display='none'" />

        <h2>بوابة الطالب</h2>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="error">@Model.ErrorMessage</div>
        }

        <form method="post">
            <label class="input-label">الرقم الجامعي</label>
            <input type="text" asp-for="Username" placeholder="أدخل رقمك الجامعي" required />

            <label class="input-label">كلمة المرور</label>
            <input type="password" asp-for="Password" placeholder="أدخل كلمة المرور" required />

            <button type="submit">دخول النظام</button>
        </form>

        <a href="/Index" class="back-home-link">عودة للصفحة الرئيسية</a>
    </div>
</body>
</html>