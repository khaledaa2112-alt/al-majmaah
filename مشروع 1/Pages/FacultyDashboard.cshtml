@page
@model مشروع_1.Pages.FacultyDashboardModel
@{
    Layout = null;
    var doctorName = "د. محمد الطوخي";
    var employeeId = "12345";
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>لوحة تحكم المحاضر - جامعة المجمعة</title>
    <style>
        body {
            margin: 0;
            background-image: url('/images/IM.jpg'); /* الخلفية الأساسية للمشروع */
            background-size: cover;
            background-attachment: fixed;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            direction: rtl;
        }

        .main-overlay {
            background-color: rgba(0, 0, 0, 0.75);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 20px;
        }

        /* 1. قسم معلومات المحاضر العلوي */
        .instructor-info {
            background: rgba(255, 255, 255, 0.95);
            padding: 25px;
            border-radius: 20px;
            width: 100%;
            max-width: 500px;
            text-align: center;
            margin-bottom: 30px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.3);
        }

        .profile-img {
            width: 110px;
            height: 110px;
            border-radius: 50%;
            border: 4px solid #28a745; /* اللون الأخضر المعتمد */
            margin-bottom: 15px;
            object-fit: cover;
        }

        .instructor-info h2 {
            color: #28a745;
            margin: 5px 0;
            font-size: 1.6rem;
        }

        .instructor-info p {
            color: #555;
            font-weight: bold;
            margin: 5px 0;
        }

        /* حاوية الأزرار الرئيسية */
        .services-container {
            display: flex;
            flex-direction: column;
            gap: 15px; /* مسافة متناسقة بين المربعات */
            width: 100%;
            max-width: 500px;
        }

        /* تصميم المربعات (الخدمات) */
        .service-item {
            background-color: #ffffff;
            padding: 20px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            text-decoration: none;
            color: #333;
            font-weight: bold;
            font-size: 1.2rem;
            transition: 0.3s;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            border-right: 8px solid #28a745;
        }

            .service-item:hover {
                transform: scale(1.02);
                background-color: #f9f9f9;
            }

        .icon-box {
            font-size: 2rem;
            margin-left: 20px;
        }

        /* زر تسجيل الخروج المقرب من المربعات */
        .logout-section {
            margin-top: 25px; /* مسافة قريبة من المربعات */
            width: 100%;
            max-width: 500px;
        }

        .btn-logout {
            display: block;
            background-color: #dc3545; /* اللون الأحمر الصريح */
            color: white;
            text-align: center;
            padding: 15px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: bold;
            font-size: 1.1rem;
            transition: 0.3s;
            box-shadow: 0 4px 10px rgba(220, 53, 69, 0.3);
        }

            .btn-logout:hover {
                background-color: #c82333;
                transform: translateY(-2px);
            }
    </style>
</head>
<body>

    <div class="main-overlay">

        <div class="instructor-info">
            <img src="/images/ss.png" class="profile-img" alt="صورة المحاضر" />
            <h2>@doctorName</h2>
            <p>الرقم الوظيفي: @employeeId</p>
            <p style="font-size: 0.9rem; color: #888;">كلية علوم الحاسب والمعلومات</p>
        </div>

        <div class="services-container">
            <a href="/InstructorProfile" class="service-item">
                <span class="icon-box">👤</span>
                <span>معلومات المحاضر</span>
            </a>

            <a href="/AttendanceTracking" class="service-item">
                <span class="icon-box">⏳</span>
                <span>رصد الغياب والتأخر</span>
            </a>

            <a href="/CourseSchedules" class="service-item">
                <span class="icon-box">📋</span>
                <span>قوائم الشعب الدراسية</span>
            </a>
        </div>

        <div class="logout-section">
            <a href="/FacultyMembers" class="btn-logout">تسجيل الخروج من النظام</a>
        </div>

    </div>

</body>
</html>