@page
@model مشروع_1.Pages.StudentDashboardModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>لوحة تحكم الطالب - جامعة المجمعة</title>
    <style>
        /* إعدادات الخلفية */
        body {
            margin: 0;
            padding: 0;
            background-image: url('/images/IM.jpg');
            background-size: cover;
            background-repeat: no-repeat;
            background-attachment: fixed;
            background-position: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            direction: rtl;
        }

        /* طبقة التعتيم */
        .main-overlay {
            background-color: rgba(0, 0, 0, 0.7);
            min-height: 100vh;
            width: 100%;
            padding: 40px 20px;
            box-sizing: border-box;
        }

        .header {
            text-align: center;
            color: white;
            margin-bottom: 50px;
        }

            .header h1 {
                margin-top: 15px;
                font-size: 2rem;
                text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
            }

        /* حاوية الأزرار (Grid) - لم يتم تغييرها */
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
            max-width: 1100px;
            margin: 0 auto;
        }

        /* تصميم المربعات - لم يتم تغييره */
        .dashboard-item {
            background-color: rgba(255, 255, 255, 0.92);
            padding: 35px 20px;
            border-radius: 15px;
            text-align: center;
            text-decoration: none;
            color: #333;
            transition: all 0.3s ease;
            border-bottom: 6px solid #28a745;
            box-shadow: 0 6px 20px rgba(0,0,0,0.3);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

            .dashboard-item:hover {
                transform: translateY(-10px);
                background-color: #ffffff;
                border-bottom-color: #d2b48c;
            }

            .dashboard-item h3 {
                margin: 0;
                font-size: 1.3rem;
                color: #1a5a2a;
            }

        /* حاوية الأزرار السفلية */
        .bottom-container {
            text-align: center;
            margin-top: 40px;
        }

        /* زر تسجيل الخروج (الأحمر) */
        .btn-logout {
            display: inline-block;
            background-color: #dc3545;
            color: white;
            padding: 12px 60px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: bold;
            transition: 0.3s;
            margin-bottom: 20px;
        }

            .btn-logout:hover {
                background-color: #c82333;
            }

        /* زر عودة للصفحة الرئيسية (بنفس نمط صورتك) */
        .back-link {
            display: block;
            color: #ffffff; /* أبيض ليتناسب مع الخلفية المظلمة */
            text-decoration: none;
            font-size: 1.1rem;
            opacity: 0.8;
            transition: 0.3s;
        }

            .back-link:hover {
                opacity: 1;
                text-decoration: underline;
            }
    </style>
</head>
<body>

    <div class="main-overlay">
        <div class="header">
            <img src="/images/logo.png" width="120" alt="Logo" onerror="this.style.display='none'" />
            <h1>بوابة الخدمات الإلكترونية للطالب</h1>
        </div>

        <div class="dashboard-grid">
            <a href="/StudentPlan" class="dashboard-item">
                <h3>خطة الطالب</h3>
            </a>
            <a href="/Absence" class="dashboard-item">
                <h3>الغياب والتأخر</h3>
            </a>
            <a href="/Sanctions" class="dashboard-item">
                <h3>العقوبات</h3>
            </a>
            <a href="/AcademicRecord" class="dashboard-item">
                <h3>السجل الأكاديمي</h3>
            </a>
            <a href="/RegisteredCourses" class="dashboard-item">
                <h3>المقررات المسجلة</h3>
            </a>
        </div>

        <div class="bottom-container">
            <a href="/StudentPortal" class="btn-logout">تسجيل الخروج</a>

            <br />

            <a href="/Index" class="back-link">عودة للصفحة الرئيسية</a>
        </div>
    </div>

</body>
</html>