@page
@model IndexModel
@{
    ViewData["Title"] = "البوابة الإلكترونية - جامعة المجمعة";
}

<style>
    /* 1. إعدادات الخلفية الأساسية */
    body {
        margin: 0;
        padding: 0;
        background-image: url('/images/IM.jpg');
        background-size: cover;
        background-repeat: no-repeat;
        background-attachment: fixed;
        background-position: center;
        direction: rtl;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* 2. طبقة الشفافية (Overlay) */
    .main-overlay {
        background-color: rgba(0, 0, 0, 0.5);
        min-height: 100vh;
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 60px;
    }

    .main-title {
        color: white;
        text-shadow: 2px 2px 10px rgba(0,0,0,0.8);
        margin-bottom: 40px;
        font-weight: bold;
    }

    .services-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
        width: 100%;
    }

    /* 3. تنسيق المستطيلات الخضراء بحواف حادة */
    .service-box {
        background-color: #28a745;
        width: 450px;
        height: 75px;
        padding: 0 25px;
        border-radius: 0; /* حواف حادة كما طلبت سابقاً */
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: 0 6px 20px rgba(0,0,0,0.4);
        transition: 0.3s ease;
        text-decoration: none !important;
        cursor: pointer;
        border: none;
    }

        .service-box:hover {
            transform: translateY(-5px);
            background-color: #218838;
        }

        .service-box h3 {
            margin: 0;
            font-size: 1.2rem;
            color: #D2B48C;
            font-weight: bold;
        }

        .service-box p {
            margin: 0;
            font-size: 0.9rem;
            color: #F5F5DC;
        }

    /* 4. تنسيق المربع الأبيض ذو الحواف الدائرية والظل خلف الشعار */
    .logo-container {
        margin-top: 40px;
        background-color: white; /* مربع أبيض خلف الشعار */
        padding: 20px;
        border-radius: 25px; /* حواف دائرية للمربع الأبيض */
        display: inline-block;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5); /* إضافة ظل للمربع الأبيض */
        text-align: center;
        border: 1px solid #ddd;
    }

    .university-logo {
        filter: drop-shadow(0 0 5px rgba(0,0,0,0.3)); /* إضافة ظل خفيف للشعار نفسه */
        display: block;
        margin: 0 auto;
    }

    .copyright {
        color: #333; /* تغيير لون النص ليكون واضحاً فوق المربع الأبيض */
        margin-top: 15px;
        font-size: 0.9rem;
        font-weight: 500;
        text-shadow: none; /* إزالة الظل من النص ليصبح أوضح */
    }
</style>

<div class="main-overlay text-center">

    <h1 class="display-4 main-title">البوابة الإلكترونية لجامعة المجمعة</h1>

    <section class="services-container">

        <a href="/StudentPortal" class="service-box">
            <h3>خدمات الطالب</h3>
            <p>الخدمات الإلكترونية للطالب</p>
        </a>

        <a href="/FacultyMembers" class="service-box">
            <h3>خدمات أعضاء هيئة التدريس</h3>
            <p>الخدمات الإلكترونية للأكاديميين</p>
        </a>

        <a href="/support" class="service-box">
            <h3>مساعدة</h3>
            <p>للإبلاغ عن مشاكل تقنية</p>
        </a>

        <div class="logo-container">
            <img src="/images/logo.png" class="university-logo" width="130" alt="شعار جامعة المجمعة" />
            <p class="copyright">جميع الحقوق محفوظة للطالب خالد عائض العتيبي</p>
        </div>

    </section>
</div>