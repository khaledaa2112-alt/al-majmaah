@page
@model مشروع_1.Pages.AttendanceTrackingModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>رصد الغياب والتأخر - جامعة المجمعة</title>
    <style>
        body {
            margin: 0;
            background-image: url('/images/IM.jpg');
            background-size: cover;
            background-attachment: fixed;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            direction: rtl;
        }

        .main-overlay {
            background-color: rgba(0, 0, 0, 0.75);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 20px;
        }

        .header-card {
            background: rgba(255, 255, 255, 0.95);
            padding: 20px;
            border-radius: 15px;
            width: 100%;
            max-width: 600px;
            text-align: center;
            margin-bottom: 25px;
            border-bottom: 5px solid #28a745;
            box-shadow: 0 8px 20px rgba(0,0,0,0.3);
        }

            .header-card h2 {
                color: #28a745;
                margin: 0;
                font-size: 1.5rem;
            }

        .sections-container {
            display: flex;
            flex-direction: column;
            gap: 12px;
            width: 100%;
            max-width: 600px;
        }

        .section-item {
            background-color: #ffffff;
            padding: 18px 25px;
            border-radius: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            text-decoration: none;
            color: #333;
            transition: 0.3s;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            border-right: 6px solid #28a745;
        }

            .section-item:hover {
                transform: scale(1.02);
                background-color: #f8f9fa;
                border-right-color: #218838;
            }

        .course-name {
            font-weight: bold;
            font-size: 1.1rem;
        }

        .section-number {
            background: #e8f5e9;
            color: #2e7d32;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.9rem;
            font-weight: bold;
            border: 1px solid #c8e6c9;
        }

        .back-btn {
            margin-top: 30px;
            padding: 12px 30px;
            background-color: #666;
            color: white;
            text-decoration: none;
            border-radius: 10px;
            font-size: 0.95rem;
            font-weight: bold;
            transition: 0.3s;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

            .back-btn:hover {
                background-color: #444;
                transform: translateY(-2px);
            }
    </style>
</head>
<body>

    <div class="main-overlay">

        <div class="header-card">
            <h2>قائمة الشعب الدراسية</h2>
            <p style="color: #666; margin-top: 5px; font-weight: bold;">اختر الشعبة للبدء في رصد الغياب</p>
        </div>

        <div class="sections-container">
            <a href="/VisualProgrammingAttendance" class="section-item">
                <span class="course-name">برمجة مرئية</span>
                <span class="section-number">شعبة: 189</span>
            </a>

            <a href="/DataStructuresAttendance" class="section-item">
                <span class="course-name">هياكل بيانات</span>
                <span class="section-number">شعبة: 575</span>
            </a>

            <a href="/SoftwareEngineeringAttendance" class="section-item">
                <span class="course-name">هندسة برمجيات</span>
                <span class="section-number">شعبة: 499</span>
            </a>

            <a href="/DatabaseManagementAttendance" class="section-item">
                <span class="course-name">إدارة قواعد البيانات</span>
                <span class="section-number">شعبة: 380</span>
            </a>

            <a href="/Programming1Attendance" class="section-item">
                <span class="course-name">برمجة 1</span>
                <span class="section-number">شعبة: 277</span>
            </a>
        </div>

        <a href="/FacultyDashboard" class="back-btn">العودة للوحة التحكم</a>
    </div>

</body>
</html>