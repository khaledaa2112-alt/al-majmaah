@page
@model مشروع_1.Pages.FacultyMembersModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>دخول أعضاء هيئة التدريس</title>
    <style>
        body {
            margin: 0;
            background-image: url('/images/IM.jpg');
            background-size: cover;
            background-attachment: fixed;
            font-family: 'Segoe UI', sans-serif;
            direction: rtl;
        }

        .main-overlay {
            background-color: rgba(0, 0, 0, 0.6);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .login-card {
            background-color: #ffffff;
            padding: 40px;
            border-radius: 20px;
            width: 100%;
            max-width: 400px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .university-logo {
            width: 120px;
            margin-bottom: 20px;
        }

        .login-title {
            color: #28a745;
            margin-bottom: 30px;
            font-size: 1.6rem;
            font-weight: bold;
        }

        .input-group {
            margin-bottom: 20px;
            text-align: right;
        }

            .input-group label {
                display: block;
                margin-bottom: 8px;
                font-weight: bold;
            }

            .input-group input {
                width: 100%;
                padding: 12px;
                border: 1px solid #ddd;
                border-radius: 8px;
                box-sizing: border-box;
            }

        .btn-login {
            background-color: #28a745;
            color: white;
            border: none;
            padding: 14px;
            border-radius: 8px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            width: 100%;
            transition: 0.3s;
        }

            .btn-login:hover {
                background-color: #218838;
            }

        .error-msg {
            color: red;
            font-size: 0.9rem;
            margin-bottom: 15px;
            display: none;
        }
    </style>
</head>
<body>
    <div class="main-overlay">
        <div class="login-card">
            <img src="/images/logo.png" class="university-logo" alt="جامعة المجمعة" />
            <div class="login-title">دخول أعضاء هيئة التدريس</div>

            <div id="error" class="error-msg">الرقم الوظيفي أو كلمة المرور غير صحيحة</div>

            <form onsubmit="return handleLogin(event)">
                <div class="input-group">
                    <label>الرقم الوظيفي</label>
                    <input type="text" id="empId" placeholder="أدخل الرقم الوظيفي" required />
                </div>
                <div class="input-group">
                    <label>كلمة المرور</label>
                    <input type="password" id="pass" placeholder="أدخل كلمة المرور" required />
                </div>
                <button type="submit" class="btn-login">دخول النظام</button>
            </form>
            <a href="/" style="display:block; margin-top:20px; color:#666; text-decoration:none;">عودة للصفحة الرئيسية</a>
        </div>
    </div>

    <script>
        function handleLogin(e) {
            e.preventDefault();
            const id = document.getElementById('empId').value;
            const pw = document.getElementById('pass').value;

            // تعيين بيانات الدخول (يمكنك تغييرها)
            if (id === "12345" && pw === "10040") {
                window.location.href = "/FacultyDashboard"; // اسم الصفحة الجديدة
            } else {
                document.getElementById('error').style.display = 'block';
            }
        }
    </script>
</body>
</html>