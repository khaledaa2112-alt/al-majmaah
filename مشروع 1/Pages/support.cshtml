@page
@model مشروع_1.Pages.SupportModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>الدعم الفني - جامعة المجمعة</title>
    <style>
        body {
            margin: 0;
            background-image: url('/images/IM.jpg');
            background-size: cover;
            background-repeat: no-repeat;
            background-attachment: fixed;
            background-position: center;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            direction: rtl;
        }

        .main-overlay {
            background-color: rgba(0, 0, 0, 0.6);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .support-card {
            background-color: rgba(255, 255, 255, 0.95);
            padding: 40px;
            border-radius: 20px;
            width: 450px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .input-group {
            margin-bottom: 20px;
            text-align: right;
        }

            .input-group label {
                display: block;
                margin-bottom: 8px;
                font-weight: bold;
            }

            .input-group textarea {
                width: 100%;
                padding: 12px;
                border-radius: 8px;
                border: 1px solid #ddd;
                min-height: 120px;
                box-sizing: border-box;
            }

        .btn-send {
            background-color: #28a745;
            color: white;
            border: none;
            padding: 12px;
            border-radius: 8px;
            width: 100%;
            cursor: pointer;
            font-size: 1.1rem;
        }
    </style>
</head>
<body>

    <div class="main-overlay">
        <div class="support-card">
            <img src="~/images/logo.png" width="100" style="margin-bottom: 15px;" />
            <h2 style="color: #28a745;">الدعم الفني</h2>

            <form method="post">
                <div class="input-group">
                    <label>اكتب مشكلتك:</label>
                    <textarea placeholder="اشرح المشكلة هنا بالتفصيل..." required></textarea>
                </div>
                <button type="submit" class="btn-send">إرسال</button>
            </form>

            <a href="/" style="display:block; margin-top:20px; color:#666; text-decoration:none;">عودة للرئيسية</a>
        </div>
    </div>

</body>
</html>