@page
@model مشروع_1.Pages.RegisteredCoursesModel
@{
    Layout = null;
    // جلب الرقم الجامعي من الجلسة
    var studentId = HttpContext.Session.GetString("UserStudentId");
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>المقررات المسجلة</title>
    <style>
        body {
            margin: 0;
            background-image: url('/images/IM.jpg');
            background-size: cover;
            background-attachment: fixed;
            font-family: 'Segoe UI', sans-serif;
            direction: rtl;
        }

        .main-overlay {
            background-color: rgba(0, 0, 0, 0.7);
            min-height: 100vh;
            padding: 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .courses-card {
            background-color: rgba(255, 255, 255, 0.95);
            padding: 30px;
            border-radius: 20px;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.4);
        }

        .course-item {
            background-color: #f8f9fa;
            margin-bottom: 12px;
            padding: 18px;
            border-radius: 10px;
            border-right: 6px solid #28a745;
            cursor: pointer;
            transition: 0.3s;
            font-size: 1.1rem;
            font-weight: 500;
            color: #333;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .course-item:hover {
                background-color: #ffffff;
                transform: scale(1.03);
            }

        .hour-badge {
            background: #28a745;
            color: white;
            padding: 2px 10px;
            border-radius: 15px;
            font-size: 0.8rem;
        }

        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.6);
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background-color: white;
            padding: 30px;
            border-radius: 15px;
            width: 320px;
            text-align: right;
            position: relative;
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
        }

        .close-btn {
            position: absolute;
            top: 10px;
            left: 10px;
            cursor: pointer;
            font-size: 24px;
            color: #999;
        }

        .modal-content h3 {
            color: #28a745;
            margin-top: 0;
            border-bottom: 2px solid #eee;
            padding-bottom: 10px;
            margin-bottom: 15px;
        }

        .info-row {
            margin: 12px 0;
            font-size: 1rem;
            color: #444;
        }

        .info-label {
            font-weight: bold;
            color: #28a745;
            margin-left: 5px;
        }
    </style>
</head>
<body>

    <div class="main-overlay">
        <div class="courses-card">
            <h2 style="text-align:center; color:#28a745; margin-bottom: 25px;">جدول المقررات المسجلة</h2>

            @if (studentId == "461102138")
            {
                <div class="course-item" onclick="showDetails('برمجة مرئية', 'د. محمد الطوخي', 'G100', '08:00 - 10:30', '3 ساعات', 'الأحد')">
                    <span>برمجة مرئية</span> <span class="hour-badge">3س</span>
                </div>

                <div class="course-item" onclick="showDetails('هياكل بيانات', 'د. عادل ثلجاوي', 'F-102', '10:00 - 12:00', '3 ساعات', 'الاثنين')">
                    <span>هياكل بيانات</span> <span class="hour-badge">3س</span>
                </div>

                <div class="course-item" onclick="showDetails('نظم إدارة قواعد بيانات', 'د. عادل ثلجاوي', 'Lab-3', '01:00 - 03:30', '3 ساعات', 'الأربعاء')">
                    <span>نظم إدارة قواعد بيانات</span> <span class="hour-badge">3س</span>
                </div>
            }
            else if (studentId == "441001234")
            {
                <div class="course-item" onclick="showDetails('الفيزياء الحديثة', 'د. محمد مصطفى', 'PH-201', '09:00 - 11:30', '3 ساعات', 'الاثنين')">
                    <span>الفيزياء الحديثة</span> <span class="hour-badge">3س</span>
                </div>

                <div class="course-item" onclick="showDetails('الديناميكا الحرارية', 'د. خالد ناظم', 'PH-105', '11:00 - 01:00', '3 ساعات', 'الثلاثاء')">
                    <span>الديناميكا الحرارية</span> <span class="hour-badge">3س</span>
                </div>

                <div class="course-item" onclick="showDetails('فيزياء البيئة', 'د. محمود جاب الله', 'PH-202', '08:00 - 10:00', '3 ساعات', 'الخميس')">
                    <span>فيزياء البيئة</span> <span class="hour-badge">3س</span>
                </div>
            }

            <div style="text-align:center; margin-top:30px;">
                <a href="/StudentDashboard" style="text-decoration:none; color:#666; font-size: 0.9rem;"> العودة الى بوابة الطالب</a>
            </div>
        </div>
    </div>

    <div id="myModal" class="modal">
        <div class="modal-content">
            <span class="close-btn" onclick="closeModal()">&times;</span>
            <h3 id="m-title"></h3>
            <div class="info-row"><span class="info-label">اليوم:</span> <span id="m-day"></span></div>
            <div class="info-row"><span class="info-label">عدد الساعات:</span> <span id="m-hours"></span></div>
            <div class="info-row"><span class="info-label">الأستاذ:</span> <span id="m-doctor"></span></div>
            <div class="info-row"><span class="info-label">القاعة:</span> <span id="m-room"></span></div>
            <div class="info-row"><span class="info-label">التوقيت:</span> <span id="m-time"></span></div>
        </div>
    </div>

    <script>
        function showDetails(name, doctor, room, time, hours, day) {
            document.getElementById('m-title').innerText = name;
            document.getElementById('m-doctor').innerText = doctor;
            document.getElementById('m-room').innerText = room;
            document.getElementById('m-time').innerText = time;
            document.getElementById('m-hours').innerText = hours;
            document.getElementById('m-day').innerText = day;
            document.getElementById('myModal').style.display = "flex";
        }

        function closeModal() {
            document.getElementById('myModal').style.display = "none";
        }

        window.onclick = function(event) {
            let modal = document.getElementById('myModal');
            if (event.target == modal) { modal.style.display = "none"; }
        }
    </script>

</body>
</html>